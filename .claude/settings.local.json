{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:apple.github.io)",
      "WebFetch(domain:foundationdb.github.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(go mod init:*)",
      "Bash(go get:*)",
      "Bash(mkdir:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(buf generate:*)",
      "Bash(mv:*)",
      "Bash(find:*)",
      "Bash(rmdir:*)",
      "Bash(tree:*)",
      "Bash(buf ls-files:*)",
      "Bash(rm:*)",
      "Bash(go build:*)",
      "Bash(go mod:*)",
      "Bash(go run:*)",
      "Bash(yay -S:*)",
      "Bash(grep:*)",
      "Bash(fdbcli:*)",
      "Bash(go list:*)",
      "Bash(/tmp:*)",
      "Bash(cp:*)",
      "Bash(gradle:*)",
      "Bash(go test:*)",
      "Bash(./gradlew:*)",
      "WebFetch(domain:buf.build)",
      "WebFetch(domain:forums.foundationdb.org)",
      "WebFetch(domain:javadoc.io)",
      "WebFetch(domain:www.tabnine.com)",
      "WebFetch(domain:go.dev)",
      "Bash(go doc:*)",
      "Bash(python3:*)",
      "Bash(systemctl status:*)",
      "WebFetch(domain:golang.testcontainers.org)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:stackoverflow.com)",
      "Bash(go clean:*)",
      "Bash(timeout 45s go test -v -run TestKeyStructure)",
      "Bash(timeout 30s go test -v -run TestKeyStructure)",
      "Bash(timeout 60s go test -v -run TestKeyStructure)",
      "Bash(timeout 60s go test -v -run TestConformanceRecordExchange)",
      "Bash(go vet:*)",
      "Bash(timeout 60s go test -v -run TestGoWriteGoReadWithTestcontainer ./conformance)",
      "Bash(timeout 2m go test -v -run TestKeyStructure ./pkg/recordlayer)",
      "Bash(docker run:*)",
      "Bash(docker exec:*)",
      "Bash(docker rm:*)",
      "Bash(timeout 60s go test -v -run TestKeyStructure ./pkg/recordlayer)",
      "Bash(timeout 60s go test -v -run TestFoundationDBContainer ./pkg/testcontainers/foundationdb)",
      "Bash(timeout 60s go test -v -run TestFoundationDBDatabaseConnection ./pkg/testcontainers/foundationdb)",
      "Bash(timeout 30s go test -v -run TestDeleteRecord ./pkg/recordlayer)",
      "Bash(timeout 90s go test:*)",
      "Bash(timeout 30s go test -v -run TestFoundationDBContainer ./pkg/testcontainers/foundationdb)",
      "Bash(timeout 120s go test -v -run TestGoWriteGoReadWithTestcontainer ./conformance)",
      "Bash(docker port:*)",
      "Bash(docker logs:*)",
      "Bash(timeout 30s go test -v -run TestFoundationDBContainer ./pkg/testcontainers/foundationdb -count=1)",
      "Bash(timeout 60s go test -v -run TestFoundationDBContainer ./pkg/testcontainers/foundationdb -count=1)",
      "Bash(timeout 60s go test -v -run TestFoundationDBContainerStartup ./pkg/testcontainers/foundationdb)",
      "Bash(timeout 30s go test -v -run TestFoundationDBContainerStartup ./pkg/testcontainers/foundationdb)",
      "Bash(timeout:*)",
      "Bash(go fmt:*)",
      "Bash(just lint:*)",
      "Bash(git add:*)"
    ],
    "deny": []
  }
}
