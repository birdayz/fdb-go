# Don't inherit shell environment into actions — use Bazel's fixed defaults
build --incompatible_strict_action_env

# (Earlier drafts used --experimental_isolated_extension_usages for a
# second isolated go_deps extension over cmd/frl/go.mod. Dropped: isolated
# extensions duplicate every transitive dep, which broke the linker when
# cmd/frl imports the root module. Bazel now uses ONE go_deps extension
# fed by root go.mod; cmd/frl's direct deps are mirrored into root go.mod.)

# Use remote JDK — no system Java dependency required
build --java_runtime_version=remotejdk_21

test --test_output=errors
test --test_summary=terse

# Produce Build Event Protocol JSONL for test report generation.
# Read by cmd/test-report to generate HTML reports from JUnit XML.
test --build_event_json_file=.bazel-bep.jsonl

# Verbose test output for report generation. Per-test timing in test.log.
# This IS part of the Bazel action fingerprint — invalidates cache once
# on first run after adding, then stays stable.
test --test_arg="-test.v"

# Testcontainers need Docker socket and HOME for config
test --test_env=HOME

# FDB version — single source of truth for all tests.
# MUST match MODULE.bazel archive_override version.
test --test_env=FDB_VERSION=7.3.75

# Override eternal timeout slot (default 900s → 3600s).
# client_test spawns ~40 FDB containers and needs ~7 min.
test --test_timeout=60,300,900,3600

# Coverage: only instrument our code, not generated types or linters.
# Without this, Bazel auto-instruments everything (including gen/ and
# pkg/linters/) which dilutes the coverage percentage.
coverage --instrumentation_filter="^//pkg/fdbgo/client[/:],^//pkg/fdbgo/fdb[/:],^//pkg/fdbgo/transport[/:],^//pkg/recordlayer[/:]"

# Limit concurrent test targets to prevent Docker socket contention.
# 9 test targets all create FDB testcontainers (socat + FDB + network each).
# Docker socket can't handle 9× parallel container creation → timeouts/hangs.
# 4 concurrent test targets works well on machines with 12+ cores.
test --local_test_jobs=4
# `bazelrunfiles`: runfiles-only suites (conformance, bindingtester) — excluded from
#   a plain `go test ./...` so it doesn't panic looking for Bazel runfiles.
# `stress`: heavy million-row stress benchmarks under //pkg/relational/sqldriver/stress.
#   The target is `manual` (runs only when invoked, e.g. by nightly), so setting the tag
#   globally is inert for `bazel test //...`; it just lets that one target compile when
#   invoked. Plain `go test ./...` doesn't set the tag, so it skips the stress package.
build --@rules_go//go/config:tags=bazelrunfiles,stress
