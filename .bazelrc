# Don't inherit shell environment into actions — use Bazel's fixed defaults
build --incompatible_strict_action_env

# Use remote JDK — no system Java dependency required
build --java_runtime_version=remotejdk_21

test --test_output=errors
test --test_summary=terse

# Testcontainers need Docker socket and HOME for config
test --test_env=HOME

# FDB version — single source of truth for all tests.
# MUST match MODULE.bazel archive_override version.
# FDB version — single source of truth for all tests.
# MUST match MODULE.bazel archive_override version.
test --test_env=FDB_VERSION=7.3.75

# Override test timeouts for CI (eternal slot = 3600s instead of 900s).
# This affects all test targets with timeout=eternal.
test --test_timeout=60,300,900,3600
