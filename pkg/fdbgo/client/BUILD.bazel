    deps = [
        "//pkg/fdbgo/transport",
        "//pkg/fdbgo/wire",
        "//pkg/fdbgo/wire/types",
        "//pkg/testcontainers/foundationdb",
        "@com_github_apple_foundationdb_bindings_go//src/fdb",
