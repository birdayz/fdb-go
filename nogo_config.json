{
  "_base": {
    "exclude_files": {
      "external/": "third-party dependencies"
    }
  },
  "gofumpt": {
    "exclude_files": {
      "gen/": "generated protobuf code",
      "\\.pb\\.go$": "generated protobuf code",
      "_vtproto\\.pb\\.go$": "generated vtprotobuf code",
      "_generated\\.go$": "generated wire type code"
    }
  },
  "noemptyiface": {
    "exclude_files": {
      "gen/": "generated protobuf code",
      "_vtproto\\.pb\\.go$": "generated vtprotobuf code",
      "\\.pb\\.go$": "generated protobuf code"
    }
  },
  "norecover": {
    "exclude_files": {
      "gen/": "generated protobuf code",
      "\\.pb\\.go$": "generated protobuf code"
    }
  },
  "shadow": {
    "only_files": {
      "DISABLED": "err shadowing is idiomatic Go"
    }
  },
  "loopclosure": {
    "only_files": {
      "DISABLED": "Go 1.22+ fixed loop variable capture"
    }
  },
  "SA1019": {
    "exclude_files": {
      "metadata_proto": "uses deprecated proto fields intentionally"
    }
  },
  "SA5011": {
    "exclude_files": {
      "_test\\.go$": "t.Fatal guards are not understood by SA5011"
    }
  },
  "SA9004": {
    "exclude_files": {
      "_generated\\.go$": "generated wire type code"
    }
  },
  "unreachable": {
    "exclude_files": {
      "pkg/relational/core/parser/gen/": "ANTLR-generated parser: dead `goto errorExit` is ANTLR's workaround for Go's label-must-be-used rule"
    }
  },
  "SA4006": {
    "exclude_files": {
      "pkg/relational/core/parser/gen/": "ANTLR-generated parser: spurious _la assignments"
    }
  }
}
