{
  "_base": {
    "exclude_files": {
      "external/": "third-party dependencies"
    }
  },
  "gofumpt": {
    "exclude_files": {
      "": "temporarily disabled while debugging wire protocol"
    }
  },
  "noemptyiface": {
    "exclude_files": {
      "gen/": "generated protobuf code",
      "_vtproto\\.pb\\.go$": "generated vtprotobuf code",
      "\\.pb\\.go$": "generated protobuf code"
    }
  },
  "shadow": {
    "only_files": {
      "DISABLED": "err shadowing is idiomatic Go"
    }
  },
  "loopclosure": {
    "only_files": {
      "DISABLED": "Go 1.22+ fixed loop variable capture"
    }
  },
  "SA1019": {
    "exclude_files": {
      "metadata_proto": "uses deprecated proto fields intentionally"
    }
  },
  "SA5011": {
    "exclude_files": {
      "_test\\.go$": "t.Fatal guards are not understood by SA5011"
    }
  }
}
