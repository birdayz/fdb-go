package conformance_test

import (
	"context"

	. "github.com/onsi/ginkgo/v2"
	. "github.com/onsi/gomega"
	"google.golang.org/protobuf/proto"

	"github.com/apple/foundationdb/bindings/go/src/fdb/tuple"
	"github.com/birdayz/fdb-record-layer-go/conformance/helpers"
	"github.com/birdayz/fdb-record-layer-go/gen"
	"github.com/birdayz/fdb-record-layer-go/pkg/recordlayer"
)

var _ = Describe("Continuation Conformance", func() {
	var (
		ctx  context.Context
		env  *helpers.TestEnvironment
		java *helpers.JavaTestRunner
	)

	BeforeEach(func() {
		ctx = context.Background()
		var err error
		env, err = helpers.SetupTestEnvironment(ctx, "continuation_conformance")
		Expect(err).NotTo(HaveOccurred())
		java = helpers.NewJavaTestRunner()
	})

	AfterEach(func() {
		if env != nil {
			env.Cleanup(ctx)
		}
	})

	Describe("Continuation Token Exchange", func() {
		It("should allow Go and Java to exchange continuation tokens seamlessly", func() {
			By("Go writing 1000 test records")
			writeTestRecords(ctx, env, 1000)

			By("Go scanning first 300 records and getting continuation")
			goContinuation1, count1 := scanWithGo(ctx, env, nil, 300)
			Expect(count1).To(Equal(300))
			Expect(goContinuation1).NotTo(BeNil())

			By("Java continuing from Go's continuation (records 300-599)")
			javaContinuation, count2, err := java.RunContinuation(
				ctx,
				env.Keyspace.Bytes(),
				goContinuation1,
				300,
				300,
				599,
			)
			Expect(err).NotTo(HaveOccurred())
			Expect(count2).To(Equal(300))
			Expect(javaContinuation).NotTo(BeNil())

			By("Go continuing from Java's continuation (records 600-899)")
			goContinuation2, count3 := scanWithGo(ctx, env, javaContinuation, 300)
			Expect(count3).To(Equal(300))
			Expect(goContinuation2).NotTo(BeNil())

			By("Java reading final records from Go's continuation (900-999)")
			finalContinuation, count4, err := java.RunContinuation(
				ctx,
				env.Keyspace.Bytes(),
				goContinuation2,
				200,
				900,
				999,
			)
			Expect(err).NotTo(HaveOccurred())
			Expect(count4).To(Equal(100))
			Expect(finalContinuation).To(BeNil(), "Should have no continuation after reading all records")
		})

		It("should handle small result sets", func() {
			By("Go writing 50 test records")
			writeTestRecords(ctx, env, 50)

			By("Go scanning first 25 records")
			goContinuation, count1 := scanWithGo(ctx, env, nil, 25)
			Expect(count1).To(Equal(25))
			Expect(goContinuation).NotTo(BeNil())

			By("Java continuing to read remaining 25 records")
			javaContinuation, count2, err := java.RunContinuation(
				ctx,
				env.Keyspace.Bytes(),
				goContinuation,
				30,
				25,
				49,
			)
			Expect(err).NotTo(HaveOccurred())
			Expect(count2).To(Equal(25))
			Expect(javaContinuation).To(BeNil(), "Should have no continuation after reading all records")
		})

		It("should handle continuation with nil start", func() {
			By("Go writing 100 test records")
			writeTestRecords(ctx, env, 100)

			By("Java starting scan from beginning")
			javaContinuation, count, err := java.RunContinuation(
				ctx,
				env.Keyspace.Bytes(),
				nil,
				50,
				0,
				49,
			)
			Expect(err).NotTo(HaveOccurred())
			Expect(count).To(Equal(50))
			Expect(javaContinuation).NotTo(BeNil())

			By("Go continuing from Java's continuation")
			goContinuation, count2 := scanWithGo(ctx, env, javaContinuation, 50)
			Expect(count2).To(Equal(50))
			Expect(goContinuation).To(BeNil())
		})
	})
})

// writeTestRecords writes N standard test records using Go
func writeTestRecords(ctx context.Context, env *helpers.TestEnvironment, count int) {
	orders := helpers.StandardOrders(0, int64(count))

	_, err := env.RecordDB.Run(ctx, func(rtx *recordlayer.FDBRecordContext) (interface{}, error) {
		store, err := recordlayer.NewStoreBuilder().
			SetContext(rtx).
			SetMetaDataProvider(env.MetaData).
			SetSubspace(env.Keyspace).
			CreateOrOpen()
		if err != nil {
			return nil, err
		}

		for _, order := range orders {
			if err := store.SaveRecord(proto.Message(order)); err != nil {
				return nil, err
			}
		}

		return nil, nil
	})
	Expect(err).NotTo(HaveOccurred())
}

// scanWithGo performs a scan using Go Record Layer and returns continuation and count
func scanWithGo(ctx context.Context, env *helpers.TestEnvironment, continuation []byte, limit int) ([]byte, int) {
	var newContinuation []byte
	var count int

	_, err := env.RecordDB.Run(ctx, func(rtx *recordlayer.FDBRecordContext) (interface{}, error) {
		store, err := recordlayer.NewStoreBuilder().
			SetContext(rtx).
			SetMetaDataProvider(env.MetaData).
			SetSubspace(env.Keyspace).
			CreateOrOpen()
		if err != nil {
			return nil, err
		}

		// Scan records with limit
		recordType := env.MetaData.GetRecordType("Order")
		var records []proto.Message
		var scanErr error

		if continuation != nil {
			records, newContinuation, scanErr = store.ScanRecordsWithContinuation(
				recordType,
				continuation,
				limit,
			)
		} else {
			// Scan from beginning
			beginKey := env.Keyspace.Pack(tuple.Tuple{int64(recordlayer.RecordKey)})
			endKey := env.Keyspace.Pack(tuple.Tuple{int64(recordlayer.RecordKey + 1)})

			records, newContinuation, scanErr = store.ScanRecordsInRangeWithContinuation(
				recordType,
				beginKey,
				endKey,
				nil,
				limit,
			)
		}

		if scanErr != nil {
			return nil, scanErr
		}

		count = len(records)
		return nil, nil
	})
	Expect(err).NotTo(HaveOccurred())

	return newContinuation, count
}
