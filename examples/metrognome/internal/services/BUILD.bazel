load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "services",
    srcs = [
        "alert.go",
        "contract.go",
        "credit.go",
        "customer.go",
        "event.go",
        "helpers.go",
        "invoice.go",
        "meter.go",
        "plan.go",
    ],
    importpath = "github.com/birdayz/fdb-record-layer-go/examples/metrognome/internal/services",
    visibility = ["//examples/metrognome:__subpackages__"],
    deps = [
        "//examples/metrognome/gen/metrognome/store/v1:store",
        "//examples/metrognome/gen/metrognome/v1:metrognome",
        "//examples/metrognome/gen/metrognome/v1/metrognomev1connect",
