        ":services",
        "//examples/metrognome/gen/metrognome/v1:metrognome",
        "//examples/metrognome/gen/metrognome/v1/metrognomev1connect",
        "//examples/metrognome/internal/billing",
        "//examples/metrognome/internal/meter",
        "//examples/metrognome/internal/storage",
        "//pkg/fdbgo/fdb",
        "//pkg/fdbgo/fdb/subspace",
        "//pkg/recordlayer",
        "//pkg/testcontainers/foundationdb",
        "@com_connectrpc_connect//:connect",
        "@com_github_onsi_gomega//:gomega",
    ],
)
