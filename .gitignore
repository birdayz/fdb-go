# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace files are intentionally committed — the cmd/frl multi-module
# setup relies on go.work, so every contributor and CI sees the same workspace.


# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Secrets and credentials
.env
.env.*
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account*.json

# OS files
.DS_Store
fdb-record-layer

# SIFT-1M benchmark data
pkg/recordlayer/testdata/*.fvecs
pkg/recordlayer/testdata/*.ivecs

# Bazel convenience symlinks. Root-anchored glob so it covers every worktree name
# (bazel-bin/out/testlogs and the workspace-named bazel-<dir>, e.g. bazel-review)
# without having to enumerate each — these are machine-local cache links and must
# never be committed.
/bazel-*
.bazel-bep.jsonl
test-report.html
.tools/
pkg/fdbgo/wire/types/v5/
binding-stress-out/
binding-stress-report.txt
bench-raw.txt
bench-results.txt
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json
test-report.html
REVIEW.md

# transient code-review scratch (codex / reviewer agents)
.review_*.txt

# stray build artifact from `go build ./example/sql`
/sql
